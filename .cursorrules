## 11. REST CALL PATTERNS (Inter-service communication)

### 11.1 RestUtils Class
```java
@Component
@Slf4j
public class RestUtils {

    @Autowired
    private RestTemplate restTemplate;
    
    @Value("${other.service.url}")
    private String otherServiceUrl;
    
    @Autowired
    private HttpServletRequest request;

    public ResponseType callOtherService(RequestType requestBody) throws ServiceException {
        try {
            log.info("RestUtils::callOtherService: Start");
            
            HttpHeaders headers = new HttpHeaders();
            headers.setContentType(MediaType.APPLICATION_JSON);
            
            // Forward Authorization header
            try {
                String authorization = request.getHeader("Authorization");
                if (StringUtils.isNotBlank(authorization)) {
                    headers.add("Authorization", authorization);
                }
            } catch (Exception e) {
                log.debug("RestUtils::callOtherService: No auth header");
            }
            
            // Accept both JSON (for errors) and expected type
            List<MediaType> acceptTypes = new ArrayList<>();
            acceptTypes.add(MediaType.APPLICATION_JSON);
            headers.setAccept(acceptTypes);
            
            HttpEntity<RequestType> entity = new HttpEntity<>(requestBody, headers);
            ResponseEntity<ResponseType> response = restTemplate.exchange(
                otherServiceUrl + "/endpoint",
                HttpMethod.POST,
                entity,
                ResponseType.class
            );
            
            return response.getBody();
        } catch (HttpServerErrorException e) {
            log.error("RestUtils::callOtherService: Server error - {}", 
                e.getResponseBodyAsString());
            // Parse error response
            ObjectMapper mapper = new ObjectMapper();
            GenericExceptionVO error = mapper.readValue(
                e.getResponseBodyAsString(), GenericExceptionVO.class);
            throw new ServiceException(error.getErrorCode(), error.getException());
        } catch (Exception e) {
            log.error("RestUtils::callOtherService: Error - ", e);
            throw new ServiceException(10001, "Error calling service");
        }
    }
}
```

