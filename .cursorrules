## 4. SERVICE PATTERN

### 4.1 Service Interface
```java
package com.{COMPANY_NAME}.{service}.service;

/**
 * Business logic interface for {Entity}.
 */
public interface {Entity}Service {
    
    {Entity}VO get{Entity}ById(String id) throws {Entity}NotFoundException;
    
    Page<{Entity}VO> getAll{Entity}s(Pageable pageable);
    
    {Entity}VO create{Entity}({Entity}VO vo) throws {Entity}Exception;
    
    {Entity}VO update{Entity}({Entity}VO vo) 
        throws {Entity}NotFoundException, {Entity}Exception;
}
```

### 4.2 Service Implementation
```java
package com.{COMPANY_NAME}.{service}.service;

@Service
@Slf4j
@RefreshScope
public class {Entity}ServiceImpl implements {Entity}Service {

    @Autowired
    private {Entity}Repository {entity}Repository;
    
    @Autowired
    private {Entity}Mapper {entity}Mapper;

    @Override
    public {Entity}VO get{Entity}ById(String id) throws {Entity}NotFoundException {
        log.info("{Entity}ServiceImpl::get{Entity}ById: Start - id: {}", id);
        
        Optional<{Entity}Model> optional = {entity}Repository.findById(id);
        if (optional.isEmpty()) {
            log.error("{Entity}ServiceImpl::get{Entity}ById: {Entity} not found for id: {}", id);
            throw new {Entity}NotFoundException({errorCode}L, id);
        }
        
        {Entity}VO result = {entity}Mapper.toVO(optional.get());
        log.info("{Entity}ServiceImpl::get{Entity}ById: End - Successfully retrieved");
        return result;
    }

    @Override
    public {Entity}VO create{Entity}({Entity}VO vo) throws {Entity}Exception {
        try {
            log.info("{Entity}ServiceImpl::create{Entity}: Start");
            
            {Entity}Model model = {entity}Mapper.toModel(vo);
            model.setCreatedOn(Instant.now());
            model.setLastModifiedOn(Instant.now());
            
            {Entity}Model saved = {entity}Repository.save(model);
            
            log.info("{Entity}ServiceImpl::create{Entity}: End - Created successfully");
            return {entity}Mapper.toVO(saved);
        } catch (Exception exception) {
            log.error("{Entity}ServiceImpl::create{Entity}: Error - ", exception);
            throw new {Entity}Exception({errorCode}L, "Error creating {Entity}");
        }
    }
}
```

